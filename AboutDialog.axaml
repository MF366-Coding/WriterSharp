<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
        x:Class="WriterSharp.AboutDialog"
        Title="About WriterSharp"
		Background="Transparent"
        TransparencyLevelHint="AcrylicBlur, Blur, Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="None"
        CanResize="False"
		Width="400"
		Height="200">
	<Grid ColumnDefinitions="Auto, *, Auto">
		<Grid Grid.Column="0" Margin="10">
			<Image Source="/Assets/Transparent.png" Width="100" Height="100"></Image>
		</Grid>
		<Grid Grid.Column="1" Margin="10">
			<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
				WriterSharp
			</TextBlock>
		</Grid>
		<Grid Grid.Column="2" Margin="10" RowDefinitions="Auto, Auto" VerticalAlignment="Center">
			<Grid Grid.Row="0">
				<Button HorizontalAlignment="Center" IsDefault="True" Background="Red">Close</Button>
			</Grid>
			<Grid Grid.Row="1">
				<Button HorizontalAlignment="Center">Learn More</Button>
			</Grid>
		</Grid>
	</Grid>
</Window>
